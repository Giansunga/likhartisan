# ── LikhArtisan Server — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit the actual .env file.

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── PayMongo ─────────────────────────────────────────────────────────────────
# Get keys from: https://dashboard.paymongo.com/settings/developers
PAYMONGO_SECRET_KEY=sk_test_your_secret_key
PAYMONGO_PUBLIC_KEY=pk_test_your_public_key
PAYMONGO_WEBHOOK_SECRET=whsk_your_webhook_secret

# ── Groq AI (LikhAI chatbot) ─────────────────────────────────────────────────
# Get key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key

# ── Lalamove (delivery quotes) ───────────────────────────────────────────────
# Get keys from: https://www.lalamove.com/api
LALAMOVE_API_KEY=pk_test_your_key
LALAMOVE_API_SECRET=sk_test_your_secret
LALAMOVE_MARKET=PH

# ── Google Maps (geocoding) ───────────────────────────────────────────────────
# Get key from: https://console.cloud.google.com/apis/credentials
# Enable: Geocoding API + Maps JavaScript API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

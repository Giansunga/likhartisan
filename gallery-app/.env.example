# ── LikhArtisan Frontend — Environment Variables ────────────────────────────
# Copy this file to .env in the gallery-app root.
# Never commit the actual .env file.

# Supabase (get from: https://supabase.com/dashboard/project/_/settings/api)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API URL (PayMongo checkout, confirm-payment, Lalamove quotes, etc.)
VITE_PAYMONGO_API_URL=http://localhost:3001

# Google Maps API key (Maps JavaScript API + Geocoding API enabled)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: Override admin/shop emails for UI-only role gating (comma-separated)
# VITE_ADMIN_EMAILS=admin@example.com,admin2@example.com
# VITE_SHOP_EMAILS=shop@example.com
